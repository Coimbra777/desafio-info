NODE_ENV=development
PORT=3000
# Exposição da UI Swagger em /api/swagger. Use "false" para desabilitar (ex.: produção).
SWAGGER_ENABLED=true

DB_HOST=sqlserver
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_DATABASE=desafio_info
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
# Pool de conexões do SQL Server (dimensionado para carga; meta 50k)
DB_POOL_MAX=20
DB_POOL_MIN=2

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
VEHICLES_CACHE_TTL=60

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_AUDIT_QUEUE=audit.events
MONGODB_URI=mongodb://mongodb:27017/aivacol_audit

JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=10m

SEED_AIVACOL_EMAIL=aivacol@example.com
SEED_AIVACOL_PASSWORD=ChangeMe123!
