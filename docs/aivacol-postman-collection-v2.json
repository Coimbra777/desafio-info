    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"aivacol@example.com\",\n  \"password\": \"ChangeMe123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns token', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.accessToken).to.be.a('string');",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
